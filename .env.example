# Copy this to src/DevInsight.API/appsettings.local.json and fill in real values
# Generate a JWT secret: any random string >= 32 characters
# Generate an AES key: openssl rand -base64 32

JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_AT_LEAST_32_CHARS!!

# 32-byte AES-256 key, Base64 encoded
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Max 256) }))
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_ENCODED_KEY_HERE===
